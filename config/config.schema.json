{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/shayanrsh/bug-bounty-toolkit/config.schema.json",
  "title": "Bug Bounty Toolkit Configuration",
  "description": "Configuration schema for the Security Tools Installer",
  "type": "object",
  "required": ["version", "settings", "categories"],
  "properties": {
    "$schema": {
      "type": "string",
      "description": "JSON Schema reference"
    },
    "version": {
      "type": "string",
      "description": "Configuration version",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "metadata": {
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "author": { "type": "string" },
        "updated": { "type": "string", "format": "date" }
      }
    },
    "settings": {
      "type": "object",
      "properties": {
        "install_prefix": { "type": "string", "default": "/usr/local" },
        "tools_directory": { "type": "string", "default": "~/tools" },
        "wordlists_directory": { "type": "string", "default": "~/wordlists" },
        "scripts_directory": { "type": "string", "default": "~/tools/scripts" },
        "log_level": {
          "type": "string",
          "enum": ["TRACE", "DEBUG", "INFO", "WARNING", "ERROR"],
          "default": "INFO"
        },
        "parallel_jobs": {
          "type": "integer",
          "minimum": 1,
          "maximum": 16,
          "default": 4
        },
        "go_tools_parallel": { "type": "boolean", "default": true },
        "skip_confirmations": { "type": "boolean", "default": false },
        "backup_existing": { "type": "boolean", "default": true },
        "verify_after_install": { "type": "boolean", "default": true },
        "auto_update_templates": { "type": "boolean", "default": true }
      }
    },
    "categories": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["enabled"],
        "properties": {
          "enabled": { "type": "boolean" },
          "tools": {
            "type": "object",
            "additionalProperties": {
              "$ref": "#/definitions/tool"
            }
          },
          "packages": {
            "type": "object",
            "additionalProperties": {
              "$ref": "#/definitions/package"
            }
          }
        }
      }
    },
    "profiles": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/definitions/profile"
      }
    },
    "hooks": {
      "type": "object",
      "properties": {
        "pre_install": { "type": "array", "items": { "type": "string" } },
        "post_install": { "type": "array", "items": { "type": "string" } },
        "pre_tool_install": { "type": "array", "items": { "type": "string" } },
        "post_tool_install": { "type": "array", "items": { "type": "string" } },
        "on_error": { "type": "array", "items": { "type": "string" } }
      }
    }
  },
  "definitions": {
    "tool": {
      "type": "object",
      "required": ["enabled"],
      "properties": {
        "enabled": { "type": "boolean" },
        "description": { "type": "string" },
        "category": { "type": "string" },
        "package": { "type": "string" },
        "repository": { "type": "string" },
        "crate": { "type": "string" },
        "requirements": { "type": "string" },
        "install_script": { "type": "string" },
        "post_install": { "type": "array", "items": { "type": "string" } },
        "dependencies": { "type": "array", "items": { "type": "string" } },
        "apt_packages": { "type": "array", "items": { "type": "string" } },
        "install_method": {
          "type": "string",
          "enum": [
            "binary",
            "apt",
            "snap",
            "pip",
            "pipx",
            "cargo",
            "go",
            "git",
            "rustup"
          ]
        },
        "version": { "type": "string" },
        "binary_url_template": { "type": "string" },
        "install_path": { "type": "string" },
        "type": { "type": "string" },
        "url": { "type": "string" },
        "extract_dir": { "type": "string" },
        "target_name": { "type": "string" },
        "target_path": { "type": "string" }
      }
    },
    "package": {
      "type": "object",
      "required": ["enabled"],
      "properties": {
        "enabled": { "type": "boolean" },
        "description": { "type": "string" }
      }
    },
    "profile": {
      "type": "object",
      "required": ["description"],
      "properties": {
        "description": { "type": "string" },
        "enabled_categories": {
          "type": "array",
          "items": { "type": "string" }
        },
        "enabled_tools": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    }
  }
}
